# 药品管理系统环境变量配置
# 复制此文件为 .env 并填入实际值

# Flask配置
FLASK_APP=app.py
FLASK_ENV=production
SECRET_KEY=your-secret-key-here

# AI API配置（OpenAI兼容格式）
# 支持：OpenAI, DeepSeek, Moonshot, 智谱, 本地部署等
AI_API_KEY=your-api-key-here
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o

# 腾讯云OCR配置（可选，用于提高中文识别准确率）
TENCENT_SECRET_ID=your-tencent-secret-id
TENCENT_SECRET_KEY=your-tencent-secret-key

# 极速数据药品查询API（可选，用于69开头条码查询药品信息）
# 注册地址: https://www.jisuapi.com/api/drug/
# 免费100次/天，足够家用药品录入
JISU_API_KEY=your-jisu-api-key

# 服务器配置
HOST=0.0.0.0
PORT=5000
